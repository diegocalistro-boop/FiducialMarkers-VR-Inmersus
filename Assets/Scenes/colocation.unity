      value: 
      objectReference: {fileID: 565664541}
    - target: {fileID: 4658076598930765765, guid: 8a9b2c3d4e5f1234567890abcdef1234, type: 3}
      propertyPath: descripcionScript
      value: "GUARDI\xC1N ANTI DRIFT. Trabaja en secreto despu\xE9s de calibrar.
        Promedia 30 frames \xF3pticos y si el visor de desvi\xF3 por error del sistema,
        te corrige invisiblemente moviendo todo el escenario (X,Z y Rotaci\xF3n)
        sin levantar el piso.\n\n-Distancia M\xE1xima Escaneo: escaneo silencioso
        si el jugador est\xE1 a menos de x metros. \n-Tiempo Interpolaci\xF3n: es
        el tiempo en segundos.\n-Ventana Tiempo: memoria a corto plazo. Si miras
        un tag, guarda su dato hasta que pasen x segundos, antes de ese tiempo tien
        que leer el segundo tag."
      objectReference: {fileID: 0}
    - target: {fileID: 4804401823177574682, guid: 8a9b2c3d4e5f1234567890abcdef1234, type: 3}
      propertyPath: descripcionScript
      value: "DICCIONARIO DE LA ARENA. Guarda las medidas y coordenadas de los AprilTags
        del mundo real en un JSON. Es el 'mapa' que los dem\xE1s leen para saber
        d\xF3nde deberian estar los objetos virtuales."
      objectReference: {fileID: 0}
    - target: {fileID: 4804401823177574682, guid: 8a9b2c3d4e5f1234567890abcdef1234, type: 3}
      propertyPath: marcadores.Array.data[0].id
